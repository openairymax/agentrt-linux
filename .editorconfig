# ===========================================================================
# agentrt-linux (AirymaxOS) EditorConfig
# https://editorconfig.org
# ===========================================================================

root = true

# ---------------------------------------------------------------------------
# Default: all files
# ---------------------------------------------------------------------------
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = tab
indent_size = 8
max_line_length = 80

# ---------------------------------------------------------------------------
# C / C++ (kernel / security / memory / cognition kthread)
# OS-STD-FMT-001: Tab-8 indentation, 80-column limit
# ---------------------------------------------------------------------------
[*.{c,h,cpp,hpp,cc,hh}]
indent_style = tab
indent_size = 8
tab_width = 8
max_line_length = 80

# ---------------------------------------------------------------------------
# Rust (cognition / cloudnative)
# OS-STD-FMT-001 Rust: 4-space indentation
# ---------------------------------------------------------------------------
[*.rs]
indent_style = space
indent_size = 4
max_line_length = 100

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
[*.py]
indent_style = space
indent_size = 4
max_line_length = 79

# ---------------------------------------------------------------------------
# Go
# ---------------------------------------------------------------------------
[*.go]
indent_style = tab
indent_size = 8
max_line_length = 100

# ---------------------------------------------------------------------------
# YAML / TOML
# ---------------------------------------------------------------------------
[*.{yml,yaml,toml}]
indent_style = space
indent_size = 2
max_line_length = 120

# ---------------------------------------------------------------------------
# JSON
# ---------------------------------------------------------------------------
[*.json]
indent_style = space
indent_size = 2
max_line_length = 120

# ---------------------------------------------------------------------------
# Markdown
# ---------------------------------------------------------------------------
[*.md]
indent_style = space
indent_size = 4
trim_trailing_whitespace = false
max_line_length = off

# ---------------------------------------------------------------------------
# Shell scripts
# ---------------------------------------------------------------------------
[*.sh]
indent_style = tab
indent_size = 8
max_line_length = 80

# ---------------------------------------------------------------------------
# Makefile / Kbuild (tab mandatory)
# ---------------------------------------------------------------------------
[{Makefile,Makefile.*,Kbuild,Kconfig}]
indent_style = tab
indent_size = 8
max_line_length = 80

# ---------------------------------------------------------------------------
# CMake
# ---------------------------------------------------------------------------
[{CMakeLists.txt,*.cmake}]
indent_style = tab
indent_size = 8
max_line_length = 80
